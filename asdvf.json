{
    "_comment": "Astroneer Dedicated Server Egg - Updated for Pelican 2026 - Manual Creation",
    "meta": {
        "version": "PTDL_v2",
        "update_url": null
    },
    "exported_at": "2026-03-07T12:00:00+00:00",
    "name": "Astroneer Dedicated Server (Fixed)",
    "author": "community + manual fix",
    "uuid": "165ead11-926d-4b3b-a5d8-86c73d09427c-fixed",
    "description": "Astroneer Dedicated Server running via Proton on Linux. Use PROTON_USE_WINED3D=1 for headless compatibility.",
    "features": null,
    "docker_images": {
        "Proton Default": "ghcr.io/ptero-eggs/steamcmd:proton",
        "Proton-GE (recommended for headless)": "ghcr.io/ptero-eggs/steamcmd:proton-ge"
    },
    "file_denylist": [],
    "startup": "PROTON_USE_WINED3D=1 PROTON_NO_ESYNC=1 PROTON_NO_FSYNC=1 proton run ./Astro/Binaries/Win64/AstroServer-Win64-Shipping.exe",
    "config": {
        "files": {
            "Astro/Saved/Config/WindowsServer/Engine.ini": {
                "parser": "ini",
                "find": {
                    "url.Port": "{{server.build.default.port}}",
                    "[SystemSettings].net.AllowEncryption": "false"
                }
            },
            "Astro/Saved/Config/WindowsServer/AstroServerSettings.ini": {
                "parser": "ini",
                "find": {
                    "[/Script/Astro.AstroServerSettings].PublicIP": "{{env.PUBLIC_IP}}",
                    "[/Script/Astro.AstroServerSettings].OwnerName": "{{env.OWNER_NAME}}",
                    "[/Script/Astro.AstroServerSettings].OwnerGuid": "{{env.OWNER_GUID}}",
                    "[/Script/Astro.AstroServerSettings].PlayerProperties": "(PlayerFirstJoinName=\"{{env.OWNER_NAME}}\",PlayerCategory=Admin,PlayerGuid=\"{{env.OWNER_GUID}}\",PlayerRecentJoinName=\"\")",
                    "[/Script/Astro.AstroServerSettings].ServerPassword": "{{env.SERVER_PWD}}",
                    "[/Script/Astro.AstroServerSettings].ServerName": "{{env.SERVER_NAME}}"
                }
            }
        },
        "startup": {
            "done": "nable to use setpriority safely"
        },
        "logs": {},
        "stop": "^C"
    },
    "scripts": {
        "installation": {
            "script": "#!/bin/bash\n# SteamCMD Installation Script for Astroneer\nif [[ \"${STEAM_USER}\" == \"\" ]] || [[ \"${STEAM_PASS}\" == \"\" ]]; then\n  STEAM_USER=anonymous\n  STEAM_PASS=\"\"\n  STEAM_AUTH=\"\"\nfi\nexport HOME=/mnt/server\ncd /tmp\nmkdir -p /mnt/server/steamcmd\ncurl -sSL -o steamcmd.tar.gz https://steamcdn-a.akamaihd.net/client/installer/steamcmd_linux.tar.gz\ntar -xzvf steamcmd.tar.gz -C /mnt/server/steamcmd\ncd /mnt/server/steamcmd\n./steamcmd.sh +force_install_dir /mnt/server +login ${STEAM_USER} ${STEAM_PASS} ${STEAM_AUTH} +@sSteamCmdForcePlatformType windows +app_update 728470 validate +quit\nmkdir -p /mnt/server/.steam/sdk32 /mnt/server/.steam/sdk64\ncp linux32/steamclient.so ../.steam/sdk32/\ncp linux64/steamclient.so ../.steam/sdk64/\necho \"Installation complete\"",
            "container": "ghcr.io/ptero-eggs/installers:debian",
            "entrypoint": "bash"
        }
    },
    "variables": [
        {
            "name": "Public IP",
            "description": "Public IP or hostname to connect to the server (use your playit.gg domain).",
            "env_variable": "PUBLIC_IP",
            "default_value": "",
            "user_viewable": true,
            "user_editable": true,
            "rules": "required|string",
            "field_type": "text"
        },
        {
            "name": "Server Owner Name",
            "description": "Steam username of the server owner (admin).",
            "env_variable": "OWNER_NAME",
            "default_value": "",
            "user_viewable": true,
            "user_editable": true,
            "rules": "required|string",
            "field_type": "text"
        },
        {
            "name": "Server Owner Guid",
            "description": "SteamID64 of the server owner (find at steamid.io).",
            "env_variable": "OWNER_GUID",
            "default_value": "",
            "user_viewable": true,
            "user_editable": true,
            "rules": "required|string",
            "field_type": "text"
        },
        {
            "name": "Server Password",
            "description": "Password required to join (leave blank for public).",
            "env_variable": "SERVER_PWD",
            "default_value": "",
            "user_viewable": true,
            "user_editable": true,
            "rules": "nullable|alpha_dash|between:1,100",
            "field_type": "text"
        },
        {
            "name": "Automatic Updates",
            "description": "Check and update server on startup (1 = Enable, 0 = Disable).",
